{
  "Home": {
    "hero_title": "Empowering Dreams, Financing Futures",
    "hero_subtitle": "A trusted microfinance institution empowering communities with accessible and reliable financial services.",
    "welcome_title": "Welcome To CYC Nepal Laghubitta Bittiya Sanstha Ltd.",
    "welcome_text1": "The CYC Nepal Laghubitta Bittiya Sanstha Ltd. is a leading Microfinance in Nepal. It was registered on 11 February 2019 as a public company as a class 'D' financial institution with the Nepal Rastra Bank under Act, 2063 and started formal microfinance operation from 15 March, 2019. CYC Nepal Laghubitta Bittiya Sanstha previously known as CYC (Chartare Youth Club) which is located in Samikshalaya Road Baglung.",
    "welcome_text2": "Currently CYC Nepal Laghubitta Bittiya Sanstha is providing microfinance services to more than 59000 deprived household from Hilly and Mountainous regions of Nepal with prime focus on low-income households, assets-less, self-employed in the informal sector to uplift their livelihood increasing involvement in economic activities and income generating activities. Besides all these financial services, it also focuses on their social development, cultural promotion, educational development, skill development & many more by its fully operated 124 branch offices which are located in All over the Nepal.",
    "read_more": "Read More",
    "full_message": "Full Message",
    "message_from_ceo_label": "Message From",
    "message_from_ceo_title": "THE CEO",
    "company_highlights_title": "Company Highlights",
    "company_highlights_description": "Key metrics showcasing our growth and commitment to serving our members.",
    "services_eyebrow": "Our Services",
    "services_heading": "Our Services",
    "services_heading_en": "Our Services",
    "services_description": "Explore the services we provide to support your financial needs.",
    "services_description_en": "Explore the services we provide to support your financial needs.",

    "message_from_ceo": "Thank you for your continued hard work, dedication, and unwavering commitment to our shared goals. Every effort you put in, whether big or small, plays a vital role in shaping our success as a team and as an organization. Your professionalism, consistency, and willingness to go the extra mile do not go unnoticed. It is your collective effort that drives our progress, strengthens our foundation, and helps us move forward even in challenging times. We deeply value the time, energy, and passion you bring to your work each day.As we continue to grow, I want to encourage each of you to keep striving for excellence, to keep learning, and to keep pushing boundaries. Let us continue supporting one another, collaborating effectively, and maintaining the high standards that define who we are.Together, we are building something meaningful and lasting. I am truly grateful to have such a committed and talented team, and I look forward to what we will achieve together in the days ahead."

     },
     "about-us": {
    "banner_title": "About us",
    "banner_description": "Learn about CYC Nepal Laghubitta Bittiya Sanstha Ltd., our purpose, and our strategic direction for inclusive and responsible finance.",
    "chairman_message_btn": "Chairman Message",
    "board_of_directors_btn": "Board of Directors",
    "introduction_label": "INTRODUCTION",
    "welcome_title": "Welcome To CYC Nepal Laghubitta Bittiya Sanstha Ltd.",
    "description_para1": "The CYC Nepal Laghubitta Bittiya Sanstha Ltd. is a leading Microfinance in Nepal. It was registered on 11 February 2019 as a public company as a class 'D' financial institution with the Nepal Rastra Bank under Act, 2063 and started formal microfinance operation from 15 March, 2019. CYC Nepal Laghubitta Bittiya Sanstha previously known as CYC (Chartare Youth Club) which is located in Samikshalaya Road Baglung.",
    "description_para2": "Currently CYC Nepal Laghubitta Bittiya Sanstha is providing microfinance services to more than 59000 deprived household from Hilly and Mountainous regions of Nepal with prime focus on low-income households, assets-less, self-employed in the informal sector to uplift their livelihood increasing involvement in economic activities and income generating activities. Besides all these financial services, it also focuses on their social development, cultural promotion, educational development, skill development & many more by its fully operated 124 branch offices which are located in All over the Nepal.",
    "vision_title": "VISION",
    "vision_description": "To be a social financial institution that contributes to poverty reduction in Nepal by helping people become socially aware, increase entrepreneurship, and become financially self-reliant.",
    "mission_title": "MISSION",
    "mission_description": "To provide financial services, financial awareness, and social awareness to the people in financially unserved areas of Nepal in an easy and sustainable manner.",
    "goals_title": "GOALS",
    "goals_list": [
      "Provide financial services to people by expanding services to remote areas of Nepal.",
      "Transform financial awareness, entrepreneurship, and livelihood skills for people in rural areas.",
      "Develop a well-managed, sustainable, and technically capable institution with highly motivated and skillful human resources.",
      "Help poor families increase their income by involving women in income-generating activities."
    ]
  },
  "chairman-message": {
    "banner_title": "Chairman Message",
    "banner_description": "A message from the Chairman outlining governance priorities and long-term commitment to inclusive financial growth.",
    "introduction_btn": "Introduction",
    "board_of_directors_btn": "Board of Directors",
    "message_label": "MESSAGE FROM",
    "message_title": "Chairman",
    "text_para_1": "It gives me great pleasure to share a few words on behalf of CYC Nepal Laghubitta Bittiya Sanstha Ltd.",
    "text_para_2": "Since our establishment in 2019, we have remained committed to empowering low-income households and underserved communities across the hilly and mountainous regions of Nepal. Our journey began with a clear vision to provide accessible financial services that create real opportunities for those who need them most. Today, with our expanding network of branches and dedicated team, we are proud to support thousands of families in improving their livelihoods.",
    "text_para_3": "At CYC Nepal Laghubitta, we believe that financial inclusion is not just about providing loans and savings facilities. It is about building confidence, encouraging entrepreneurship, and creating sustainable income-generating opportunities. Alongside our financial services, we continue to promote social awareness, education, skill development, and cultural values within the communities we serve.",
    "text_para_4": "Our progress would not have been possible without the trust of our clients, the dedication of our staff, and the continuous support of our stakeholders. We remain committed to strengthening this trust by maintaining transparency, accountability, and responsible banking practices.",
    "text_para_5": "As we move forward, we will continue to expand our outreach, enhance service quality, and contribute meaningfully to the economic and social development of Nepal.",
    "text_para_6": "Thank you for your continued trust and support.",
    "signature_name": "Padhmanath Sharma",
    "signature_designation": "CHAIRMAN"
  },
